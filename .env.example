# Supabase Configuration
# Public (safe to expose in client code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin Password
# Generate with: npm run generate:hash
ADMIN_PASSWORD_HASH=$2a$10$YQv8PlkzYlKSHEZA8TK1BOhqwM5EEG/JGvgCGLxAChD9Gw.6Ey5hS

# JWT Secret for session tokens
JWT_SECRET=your-secure-random-jwt-secret

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace values with your actual Supabase credentials
# 3. Get credentials from:
#    - NEXT_PUBLIC_SUPABASE_URL: Supabase Dashboard → Settings → API
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY: Supabase Dashboard → Settings → API (anon/public)
#    - SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard → Settings → API (service_role)
# 4. Keep SUPABASE_SERVICE_ROLE_KEY secret (never commit to git)
